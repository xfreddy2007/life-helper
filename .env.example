# ============================================================
# 居家生活小幫手 — 環境變數範本
# 正式路徑：apps/bot/.env（專案 scaffold 後請移動此檔案）
# 使用方式：複製此檔案為 .env，填入實際值後即可使用
# 注意：.env 含敏感資訊，絕對不可 commit 至 git
# ============================================================

# ── LINE Bot ──────────────────────────────────────────────
# 取得方式：LINE Developer Console → Messaging API Channel
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token
LINE_CHANNEL_SECRET=your_channel_secret
LINE_GROUP_ID=your_group_id

# ── Anthropic Claude API ──────────────────────────────────
# 取得方式：https://console.anthropic.com → API Keys
ANTHROPIC_API_KEY=your_anthropic_api_key

# ── Database ──────────────────────────────────────────────
# 本地開發（Docker Compose）
DATABASE_URL=postgresql://lifehelper:lifehelper_dev@localhost:5432/life_helper
# 正式環境（Fly Managed Postgres 會自動注入，不需手動填寫）

# ── Redis ─────────────────────────────────────────────────
# 本地開發（Docker Compose）
REDIS_URL=redis://localhost:6379
# 正式環境範例（Upstash TLS，部署後填入）：
# REDIS_URL=rediss://default:<token>@<host>.upstash.io:6379

# ── Sentry（可選，錯誤監控）─────────────────────────────
# 取得方式：https://sentry.io → 建立新專案 → DSN
SENTRY_DSN=

# ── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
